# ============================================================
# PTB Session Tracker — Environment Variables
# ============================================================
# SETUP:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your values below
#   3. .env.local is in .gitignore — it NEVER goes to GitHub
#   4. In Vercel: paste these same values in Settings → Environment Variables
# ============================================================

# ----------------------------------------------------------
# NEON DATABASE (Required)
# Get this from: neon.tech → your project → Connection Details
# Use the "Pooled connection" string
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------
# JWT SECRET (Required)
# Generate a random secret:  openssl rand -base64 32
# ----------------------------------------------------------
JWT_SECRET=your-super-secret-key-here-change-this

# ----------------------------------------------------------
# App URL (Required for email links)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app (or custom domain)
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
